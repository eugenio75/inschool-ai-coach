# InSchool — Environment Variables
VITE_SUPABASE_PROJECT_ID=""
VITE_SUPABASE_PUBLISHABLE_KEY=""
VITE_SUPABASE_URL=""

# ── AZAR CHAIN — InSchool Blockchain ──────────────────────────────────────────
# Blockchain privata: Azar Chain · Chain ID 24780 · rpc.azarlabs.com
# La firma delle transazioni avviene LATO BACKEND (sicuro per produzione)
# Il frontend chiama solo gli endpoint REST del backend

# URL backend API Azar Chain
# Produzione: https://api-chain.azarlabs.com
# Sviluppo locale: http://127.0.0.1:23100
VITE_CHAIN_API_URL=https://api-chain.azarlabs.com
CHAIN_API_URL=https://api-chain.azarlabs.com

# API Key opzionale per proteggere gli endpoint
VITE_CHAIN_API_KEY=
CHAIN_API_KEY=

# Segreto HMAC per anonimizzare ID utente (mai dati personali on-chain)
# Genera: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VITE_HMAC_SECRET=
HMAC_SECRET=

# Explorer
VITE_CHAIN_EXPLORER_URL=https://explorer.azarlabs.com

# Indirizzi smart contract InSchool (già deployati su Azar Chain)
VITE_RBAC_CONTRACT_ADDR=0x8b0543690dF6dAFfCBf4c56D82778C9Ed9bb7332
VITE_GOVERNANCE_CONTRACT_ADDR=0x7337DEDceedACed7Bcb52Bb552e001D71b2596a5
VITE_CONSENT_CONTRACT_ADDR=0x74Fc0D36B46433887aE39EA9B43b67f642d5715a
VITE_CREDENTIAL_CONTRACT_ADDR=0x57457E2a5B2Aa0cE246E3873306a95277f7E341A
